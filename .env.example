# ==========================================
# SwiftForge — Environment Configuration Example
# Copy this file to .env and fill in your values
# ==========================================

APP_NAME=SwiftForge
APP_ENV=development
APP_DEBUG=true

# Local Execution Engine Settings
SWIFT_EXEC_TIMEOUT_SECONDS=10
DEFAULT_COMPILER_PATH=/usr/bin/swift

# External Practice API Endpoints
JSON_PLACEHOLDER_API_URL=https://jsonplaceholder.typicode.com

# Notarization (used by create_dmg.sh / publish_release.sh via `xcrun notarytool`)
# Reuses your App Store Connect API key (App Store Connect -> Users and Access -> Integrations)
# instead of an Apple ID app-specific password, since the key can't get "lost" the same way
# and doesn't require re-authenticating with 2FA.
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
# Paste the full contents of the downloaded AuthKey_XXXX.p8 file (or a base64 copy of it) below
APP_STORE_CONNECT_API_KEY_KEY=
