# ==========================================
# SwiftForge — Environment Configuration Example
# Copy this file to .env and fill in your values
# ==========================================

APP_NAME=SwiftForge
APP_ENV=development
APP_DEBUG=true

# Local Execution Engine Settings
SWIFT_EXEC_TIMEOUT_SECONDS=10
DEFAULT_COMPILER_PATH=/usr/bin/swift

# External Practice API Endpoints
JSON_PLACEHOLDER_API_URL=https://jsonplaceholder.typicode.com
