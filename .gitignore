# ==========================================
# SwiftForge — macOS & Xcode .gitignore
# ==========================================

# ── macOS System Files ──
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
.caches
ehthumbs.db
Thumbs.db

# ── Xcode DerivedData, Build Archives & Packages ──
build/
DerivedData/
*.xcarchive
*.dmg
*.pkg
*.app
*.ipa
*.xcresult
*.hmap
*.dSYM.zip
*.dSYM

# ── Xcode User Data & Personal Schemes ──
xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcworkspace/xcshareddata/WorkspaceSettings.xcsettings
*.xcodeproj/project.xcworkspace/xcshareddata/WorkspaceSettings.xcsettings
*.xcscmblueprint
*.xccheckout
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# ── Fastlane Generated Reports & Outputs ──
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/
fastlane/test_output/
fastlane/README.md

# ── Node.js / Playwright Automation ──
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
playwright-report/
test-results/

# ── Swift Package Manager & CocoaPods ──
.build/
Packages/
.swiftpm/
Pods/
Podfile.lock
xcframeworks/

# ── Xcode Playgrounds & Scratches ──
timeline.xctimeline
playground.xcworkspace

# ── Temporary Execution Files & Local Logs ──
*.log
app_test.log
interview_practice_*.swift
*.tmp
*.swp
*~

# ── Local User Data & Runtime Databases ──
user_activity.json
dsa_user_activity.json
*.sqlite
*.sqlite-wal
*.sqlite-shm

# ── Project Backup Folders ──
.backups/
backup_temp/

# ── IDE & Editor Artifacts ──
.antigravity/
.gemini/
.vscode/
.idea/

# ── Sensitive Credentials, API Keys & Certificates ──
.env
.env.local
.env.*.local
*.p12
*.p8
AuthKey_*.p8
*.pem
*.cer
*.key
*.mobileprovision
*.provisionprofile
